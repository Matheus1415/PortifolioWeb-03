{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": true, // Geralmente 'true' se o Vite/esbuild faz o build final
    "skipLibCheck": true,
    "checkJs": false,
    "ignoreDeprecations": "5.0",
    "noImplicitAny": false,
    "suppressImplicitAnyIndexErrors": true,
    "strict": false // Desativa todas as checagens rigorosas de uma vez
  }
}