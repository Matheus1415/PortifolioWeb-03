{
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.node.json"
    }
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "noEmit": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "5.0",
    // Esta é a principal para ignorar erros no build:
    "noImplicitAny": false,
    "suppressImplicitAnyIndexErrors": true
  }
}
